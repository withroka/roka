export const mock = {};

mock[`request() makes request > fetch 1`] =
[
  {
    input: [
      "https://example.com/",
      {
        headers: {},
        method: "GET",
        redirect: "follow",
      },
    ],
    output: [
      '<!doctype html><html lang="en"><head><title>Example Domain</title><meta name="viewport" content="width=device-width, initial-scale=1"><style>body{background:#eee;width:60vw;margin:15vh auto;font-family:system-ui,sans-serif}h1{font-size:1.5em}div{opacity:0.8}a:link,a:visited{color:#348}</style></head><body><div><h1>Example Domain</h1><p>This domain is for use in documentation examples without needing permission. Avoid use in operations.</p><p><a href="https://iana.org/domains/example">Learn more</a></p></div></body></html>\n',
      {
        headers: {
          "cf-cache-status": "HIT",
          "cf-ray": "9f1f6b4ec8c11c9a-AMS",
          "content-type": "text/html",
          "last-modified": "Sat, 18 Apr 2026 00:51:00 GMT",
          age: "12905",
          allow: "GET, HEAD",
          date: "Sat, 25 Apr 2026 18:30:28 GMT",
          server: "cloudflare",
        },
        status: 200,
        statusText: "OK",
      },
    ],
  },
];

mock[`request() rejects failed response > fetch 1`] =
[
  {
    input: [
      "https://example.com/not-found",
      {
        headers: {},
        method: "GET",
        redirect: "follow",
      },
    ],
    output: [
      '<!doctype html><html lang="en"><head><title>Example Domain</title><meta name="viewport" content="width=device-width, initial-scale=1"><style>body{background:#eee;width:60vw;margin:15vh auto;font-family:system-ui,sans-serif}h1{font-size:1.5em}div{opacity:0.8}a:link,a:visited{color:#348}</style></head><body><div><h1>Example Domain</h1><p>This domain is for use in documentation examples without needing permission. Avoid use in operations.</p><p><a href="https://iana.org/domains/example">Learn more</a></p></div></body></html>\n',
      {
        headers: {
          "cf-cache-status": "HIT",
          "cf-ray": "9f1f6b4f1ae8e459-AMS",
          "content-type": "text/html",
          age: "3544",
          date: "Sat, 25 Apr 2026 18:30:28 GMT",
          server: "cloudflare",
        },
        status: 404,
        statusText: "Not Found",
      },
    ],
  },
];

mock[`request() passes common headers > fetch 1`] =
[
  {
    input: [
      "https://example.com/",
      {
        headers: {
          "user-agent": "agent",
          referer: "referrer",
