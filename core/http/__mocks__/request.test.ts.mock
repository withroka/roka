];

mock[`request({ allowedErrors }) accepts retryable status code > fetch 1`] =
[
  {
    input: [
      "https://httpbin.org/status/429",
      {
        headers: {},
        method: "GET",
        redirect: "follow",
      },
    ],
    output: [
      "",
      {
        headers: {
          "access-control-allow-credentials": "true",
          "access-control-allow-origin": "*",
          "content-length": "0",
          "content-type": "text/html; charset=utf-8",
          date: "Sat, 25 Apr 2026 18:47:15 GMT",
          server: "gunicorn/19.9.0",
        },
        status: 429,
        statusText: "Too Many Requests",
      },
    ],
  },
  {
    input: [
      "https://httpbin.org/status/429",
      {
        headers: {},
        method: "GET",
        redirect: "follow",
      },
    ],
    output: [
      "",
      {
        headers: {
          "access-control-allow-credentials": "true",
          "access-control-allow-origin": "*",
          "content-length": "0",
          "content-type": "text/html; charset=utf-8",
          date: "Sat, 25 Apr 2026 18:47:15 GMT",
          server: "gunicorn/19.9.0",
        },
        status: 429,
        statusText: "Too Many Requests",
      },
    ],
  },
  {
    input: [
      "https://httpbin.org/status/429",
      {
        headers: {},
        method: "GET",
        redirect: "follow",
      },
    ],
    output: [
      "",
      {
        headers: {
          "access-control-allow-credentials": "true",
          "access-control-allow-origin": "*",
          "content-length": "0",
          "content-type": "text/html; charset=utf-8",
          date: "Sat, 25 Apr 2026 18:47:15 GMT",
          server: "gunicorn/19.9.0",
        },
        status: 429,
        statusText: "Too Many Requests",
      },
    ],
  },
];

mock[`request({ cache }) can cache response > reload > fetch 1`] =
[
  {
    input: [
      "https://example.com/",
      {
        headers: {},
        method: "GET",
        redirect: "follow",
      },
    ],
    output: [
      '<!doctype html><html lang="en"><head><title>Example Domain</title><meta name="viewport" content="width=device-width, initial-scale=1"><style>body{background:#eee;width:60vw;margin:15vh auto;font-family:system-ui,sans-serif}h1{font-size:1.5em}div{opacity:0.8}a:link,a:visited{color:#348}</style></head><body><div><h1>Example Domain</h1><p>This domain is for use in documentation examples without needing permission. Avoid use in operations.</p><p><a href="https://iana.org/domains/example">Learn more</a></p></div></body></html>\n',
      {
        headers: {
          "cf-cache-status": "HIT",
          "cf-ray": "9f1f83e239352d00-AMS",
          "content-type": "text/html",
          "last-modified": "Sat, 18 Apr 2026 00:51:00 GMT",
          age: "13912",
          allow: "GET, HEAD",
          date: "Sat, 25 Apr 2026 18:47:15 GMT",
          server: "cloudflare",
        },
        status: 200,
