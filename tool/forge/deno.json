{
  "name": "@roka/forge",
  "version": "0.2.0",
  "exports": {
    ".": "./forge.ts",
    "./bump": "./bump.ts",
    "./changelog": "./changelog.ts",
    "./compile": "./compile.ts",
    "./release": "./release.ts",
    "./testing": "./testing.ts",
    "./version": "./version.ts",
    "./workspace": "./workspace.ts"
  },
  "forge": {
    "main": "forge.ts"
  },
  "permissions": {
    "default": {
      "env": [
        "GIT_NAME",
        "GIT_EMAIL",
        "GITHUB_TOKEN",
        "HOME"
      ],
      "read": true,
      "write": true,
      "net": [
        "api.github.com",
        "uploads.github.com"
      ],
      "run": [
        "deno",
        "git",
        "tar",
        "zip"
      ]
    }
  },
  "test": {
    "permissions": {
      "read": true,
      "write": true,
      "run": true,
      "env": [
        "GITHUB_TOKEN",
        "HOME"
      ],
      "net": [
        "api.github.com"
      ]
    }
  }
}
